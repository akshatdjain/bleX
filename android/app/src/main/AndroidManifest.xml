<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════════════════════════
         PERMISSIONS — Each one explained
         ═══════════════════════════════════════════════════════════════ -->

    <!-- BLE: Needed to discover and scan Bluetooth Low Energy devices -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />

    <!-- Android 12+: Fine-grained BLE permissions -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Location: Android requires location permission for BLE scanning
         because BLE beacons can be used to determine physical location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground Service: Required to run a persistent service with notification -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Network: For MQTT communication to the broker -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- WiFi State: Needed to read hotspot (soft AP) enabled status -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- Wake Lock: Prevents CPU from sleeping during BLE scans -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Boot: Auto-start the scanner service when the tablet boots up -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Battery: Request exemption from battery optimization (Doze mode) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Schedule exact alarms for service restart watchdog -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Android 13+: Required to show any notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Android 16+: Required for Live Update (Rich Ongoing) notifications -->
    <uses-permission android:name="android.permission.POST_PROMOTED_NOTIFICATIONS" />

    <!-- Declare that this app requires BLE hardware -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <application
        android:name=".BleXApp"
        android:allowBackup="false"
        android:usesCleartextTraffic="true"
        android:icon="@mipmap/ic_launcher"
        android:label="BleX"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar"
        tools:targetApi="35">

        <!-- ═══════════════════════════════════════════════════════════
             MAIN ACTIVITY — Just a launcher that starts the service
             ═══════════════════════════════════════════════════════════ -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.Light.NoActionBar">
            <intent-filter>
                <!-- This makes it appear in the app launcher -->
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ═══════════════════════════════════════════════════════════
             BLE SCANNER SERVICE — The heart of the app
             Runs as a foreground service with type "connectedDevice"
             ═══════════════════════════════════════════════════════════ -->
        <service
            android:name=".BleScannerService"
            android:enabled="true"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- ═══════════════════════════════════════════════════════════
             BOOT RECEIVER — Starts the service when tablet boots
             ═══════════════════════════════════════════════════════════ -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <!-- Standard Android boot completed broadcast -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- Some OEMs (like HTC) use this instead -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <!-- Reboot completed on some devices -->
                <action android:name="android.intent.action.REBOOT" />
            </intent-filter>
        </receiver>

        <!-- ═══════════════════════════════════════════════════════════
             SERVICE RESTART RECEIVER — Safety net to restart if killed
             ═══════════════════════════════════════════════════════════ -->
        <receiver
            android:name=".ServiceRestartReceiver"
            android:enabled="true"
            android:exported="false" />

    </application>

</manifest>
